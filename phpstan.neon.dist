includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    level: 6

    paths:
        - app/
        - config/
        - database/
        - routes/
        - tests/

    tmpDir: storage/framework/cache/phpstan

    checkModelProperties: true
    checkUnusedViews: false
    checkMissingTranslations: false
